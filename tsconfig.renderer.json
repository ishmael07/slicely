{
  // The renderer runs in a browser (Chromium) context, NOT Node. It is compiled
  // separately as an ES module so the emitted JS has no CommonJS `exports`/
  // `require` (which throw in a plain browser). All its imports are `import type`
  // and erase at compile time, so the output is dependency-free and loads via
  // <script type="module">.
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2020",
    "moduleResolution": "Node",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "outDir": "dist-web",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": []
  },
  "include": ["src/renderer/**/*.ts", "src/shared/**/*.ts"]
}
