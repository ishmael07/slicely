{
  "name": "slicely",
  "version": "0.1.0",
  "description": "Slicely — an AI agent that finds free 3D-printable models online and drives PrusaSlicer for you. macOS chat-bar app.",
  "main": "dist/main/main.js",
  "author": "ishmael07",
  "license": "MIT",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.renderer.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "start": "npm run build && electron dist/main/main.js",
    "dev": "npm run build && electron dist/main/main.js",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.105.0",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "@types/node": "20.19.9",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "dev.ishmael.slicely",
    "productName": "Slicely",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg"
      ]
    }
  }
}
