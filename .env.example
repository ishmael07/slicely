# ─────────────────────────────────────────────────────────────────────────────
# Slicely configuration. Copy this file to ".env" and fill in your keys:
#
#     cp .env.example .env
#
# Lines beginning with "#" are comments. Do NOT wrap values in quotes.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ────────────────────────────────────────────────────────────────

# Anthropic API key — powers the Slicely agent.
# Get one at https://console.anthropic.com/  (Settings → API Keys).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Thingiverse "App Token" — required for the ONLY marketplace Slicely can
# download from directly. Free: sign in at https://www.thingiverse.com/apps/create
# create an app (any name), and copy the "App Token" it shows you.
# Without this, Thingiverse search/download is disabled (Printables &
# MakerWorld search still work, but those open in your browser to download).
THINGIVERSE_APP_TOKEN=

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Which Claude model the agent uses. Default is Anthropic's most capable
# widely-released coding/agentic model. Override only if you know you want to.
#   claude-opus-4-8    (default — most capable)
#   claude-sonnet-4-6  (faster / cheaper)
#   claude-haiku-4-5   (fastest / cheapest)
SLICELY_MODEL=claude-opus-4-8

# Reasoning effort for the agent loop: low | medium | high | xhigh | max
# Higher = better tool decisions, more tokens. "high" is a good balance.
SLICELY_EFFORT=high

# Absolute path to the PrusaSlicer binary. Leave blank to auto-detect the
# standard macOS install at:
#   /Applications/PrusaSlicer.app/Contents/MacOS/PrusaSlicer
PRUSASLICER_PATH=

# Absolute path to a PrusaSlicer config bundle (.ini) exported from the GUI
# (File → Export → Export Config…). Strongly recommended — without it, slices
# use generic built-in defaults that won't match your real printer/filament.
# Leave blank to slice against PrusaSlicer's built-in defaults.
PRUSASLICER_CONFIG_INI=

# Where downloaded models and sliced G-code are stored.
# Leave blank to use ~/Slicely
SLICELY_WORKDIR=
